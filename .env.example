# Environment Variables — Duelo

## Supabase
# Dashboard -> Project Settings -> API -> Project URL
NEXT_PUBLIC_SUPABASE_URL=

# Dashboard -> Project Settings -> API -> anon public key
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Dashboard -> Project Settings -> API -> service_role key (server-only, NEVER expose to client)
SUPABASE_SERVICE_ROLE_KEY=

# Dashboard -> Project Settings -> Database -> Connection string (session pooler, port 5432)
# Used by Drizzle for migrations
DATABASE_URL=

# Public URL of this deployment (used to build the PayGate return_url)
NEXT_PUBLIC_APP_URL=

## PayGate (Phase 1-03) — Duelo never talks to PaySuite directly. PayGate is
## the single owner of the PaySuite relationship across all its apps (one
## PaySuite webhook URL, fanned out to each app). See payment-gateway repo
## and lib/paygate-client.ts. Values below are given by that repo's
## `npm run app:register -- --slug=duelo ...`.
PAYGATE_BASE_URL=
PAYGATE_API_KEY=
PAYGATE_CALLBACK_SECRET=

## Sports Data (Phase 3)
# API-Football / api-sports.io Pro tier key
SPORTS_API_KEY=
